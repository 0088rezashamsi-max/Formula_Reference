public class class_Mathematics_data_Formula
{
    public struct Formulas_mathematics
    {
        public const string M1 = "Area of circle = π r²";
        public const string M2 = "Pythagorean theorem: a² + b² = c²";
        public const string M3 = "Quadratic: ax² + bx + c = 0";
        public const string M4 = "Volume of sphere = (4/3)π r³";
        public const string M5 = "Area of triangle = ½ × base × height";
        public const string M6 = "Circumference of circle = 2πr";
        public const string M7 = "Area of rectangle = length × width";
        public const string M8 = "Volume of cylinder = π r² h";
        public const string M9 = "Area of trapezoid = ½(a+b)h";
        public const string M10 = "n! (Factorial)";
    }

    public static void ViewAllFormulas()
    {
        var fields = typeof(Formulas_mathematics).GetFields(BindingFlags.Public | BindingFlags.Static | BindingFlags.FlattenHierarchy);
        Console.WriteLine("\nAll Mathematics Formulas:");
