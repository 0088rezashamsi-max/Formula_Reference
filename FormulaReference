public class class_Physics_data_Formula
{
    public struct Formulas_physics
    {
        public const string F1 = "Q = m c ΔT (Heat)";
        public const string F2 = "F = m a (Force)";
        public const string F3 = "P = W / t (Power)";
        public const string F4 = "E = m c² (Energy)";
        public const string F5 = "v = u + a t (Velocity)";
        public const string F6 = "s = u t + ½ a t² (Displacement)";
        public const string F7 = "v² = u² + 2 a s (Velocity squared)";
        public const string F8 = "F = G m₁m₂ / r² (Gravitational force)";
        public const string F9 = "P = ρ g h (Fluid pressure)";
        public const string F10 = "V = I R (Ohm's law)";
    }

    public static void ViewAllFormulas()
    {
        var fields = typeof(Formulas_physics).GetFields(BindingFlags.Public | BindingFlags.Static | BindingFlags.FlattenHierarchy);
        Console.WriteLine("\nAll Physics Formulas:");
        int i = 1;
        foreach (var f in fields)
            if (f.IsLiteral && f.FieldType == typeof(string))
                Console.WriteLine($"{i++}. {f.GetValue(null)}");
        Console.WriteLine();
    }

    public void metde_Formula_calculations()
    {
        Console.WriteLine("Type the formula name or part of it, or type 'view all formulas'.");
        string search = Console.ReadLine()?.Trim();

        if (search?.ToLower() == "view all formulas")
        {
            ViewAllFormulas();
            return;
        }

        var fields = typeof(Formulas_physics).GetFields(BindingFlags.Public | BindingFlags.Static | BindingFlags.FlattenHierarchy);
        bool found = false;

        foreach (var field in fields)
        {
            if (field.IsLiteral && field.FieldType == typeof(string))
            {
                string formulaValue = field.GetValue(null)?.ToString();
                if (!string.IsNullOrEmpty(formulaValue) && formulaValue.Contains(search, StringComparison.OrdinalIgnoreCase))
                {
                    Console.WriteLine($"\nFormula found: {field.Name} = {formulaValue}");
                    found = true;
                    SolvePhysicsFormula(field.Name);
                    break;
                }
            }
        }

        if (!found)
            Console.WriteLine("No formula found with this term.");
        Console.WriteLine();
    }

    private void SolvePhysicsFormula(string formulaName)
    {
        Console.WriteLine("Enter the values. If a value is unknown, enter 0.");
        double GetDouble(string prompt)
        {
            double val;
            while (true)
            {
                Console.Write(prompt);
                if (double.TryParse(Console.ReadLine(), out val))
                    return val;
                Console.WriteLine("Invalid input. Please enter a number.");
            }
        }

        switch (formulaName)
        {
            case "F1": // Q = m c ΔT
                double m = GetDouble("Enter m (mass): ");
                double c = GetDouble("Enter c (specific heat): ");
                double dT = GetDouble("Enter ΔT (temperature change): ");
                Console.WriteLine($"\nResult: Q = {m} × {c} × {dT} = {m * c * dT} Joules");
                break;

            case "F2": // F = m a
                double mass = GetDouble("Enter m (mass): ");
                double acc = GetDouble("Enter a (acceleration): ");
                Console.WriteLine($"\nResult: F = {mass} × {acc} = {mass * acc} Newtons");
                break;

            case "F3": // P = W / t
                double W = GetDouble("Enter W (work): ");
                double t = GetDouble("Enter t (time): ");
                Console.WriteLine($"\nResult: P = {W} / {t} = {W / t} Watts");
                break;

            case "F4": // E = m c²
                double m2 = GetDouble("Enter m (mass): ");
                Console.WriteLine($"\nResult: E = {m2} × 9e16 = {m2 * 9e16} Joules");
                break;

            case "F5": // v = u + at
                double u = GetDouble("Enter u (initial velocity): ");
                double a = GetDouble("Enter a (acceleration): ");
                double t2 = GetDouble("Enter t (time): ");
                Console.WriteLine($"\nResult: v = {u} + {a} × {t2} = {u + a * t2} m/s");
                break;

            case "F6": // s = ut + ½at²
                double u2 = GetDouble("Enter u (initial velocity): ");
                double a2 = GetDouble("Enter a (acceleration): ");
                double t3 = GetDouble("Enter t (time): ");
                Console.WriteLine($"\nResult: s = {u2}×{t3} + ½×{a2}×{t3}² = {u2 * t3 + 0.5 * a2 * t3 * t3} m");
                break;

            case "F7": // v² = u² + 2as
                double u3 = GetDouble("Enter u (initial velocity): ");
                double a3 = GetDouble("Enter a (acceleration): ");
                double s = GetDouble("Enter s (displacement): ");
                double v2 = u3 * u3 + 2 * a3 * s;
                Console.WriteLine($"\nResult: v² = {u3}² + 2×{a3}×{s} = {v2} → v = {Math.Sqrt(v2)} m/s");
                break;

            case "F8": // F = G m₁m₂ / r²
                double G = 6.674e-11;
                double m1 = GetDouble("Enter m1 (mass 1): ");
                double m2b = GetDouble("Enter m2 (mass 2): ");
                double r = GetDouble("Enter r (distance): ");
                double F = G * m1 * m2b / (r * r);
                Console.WriteLine($"\nResult: F = {G} × {m1} × {m2b} / {r}² = {F} N");
                break;

            case "F9": // P = ρ g h
                double rho = GetDouble("Enter ρ (density): ");
                double g = GetDouble("Enter g (gravity, default 9.8): ");
                double h = GetDouble("Enter h (height): ");
                Console.WriteLine($"\nResult: P = {rho} × {g} × {h} = {rho * g * h} Pa");
                break;

            case "F10": // V = IR
                double I = GetDouble("Enter I (current): ");
                double R = GetDouble("Enter R (resistance): ");
                Console.WriteLine($"\nResult: V = {I} × {R} = {I * R} Volts");
                break;

            default:
                Console.WriteLine("Calculation for this formula is not implemented yet.");
                break;
        }
    }
}

