public class class_Chemistry_data_Formula
{
    public struct Formulas_chemistry
    {
        public const string C1 = "Molarity: M = n / V";
        public const string C2 = "Ideal gas: PV = nRT";
        public const string C3 = "pH = -log[H+]";
        public const string C4 = "Density: ρ = m / V";
        public const string C5 = "Mass percent = (mass solute / mass solution) × 100";
        public const string C6 = "ppm = (mass solute / mass solution) × 10⁶";
        public const string C7 = "Reaction rate = Δ[A] / Δt";
        public const string C8 = "Equilibrium constant Kc = [C]^c [D]^d / [A]^a [B]^b";
        public const string C9 = "Raoult's law: P_solution = X_solvent × P°_solvent";
        public const string C10 = "Enthalpy change: ΔH = H_products - H_reactants";
    }

    public static void ViewAllFormulas()
    {
        var fields = typeof(Formulas_chemistry).GetFields(BindingFlags.Public | BindingFlags.Static | BindingFlags.FlattenHierarchy);
        Console.WriteLine("\nAll Chemistry Formulas:");
