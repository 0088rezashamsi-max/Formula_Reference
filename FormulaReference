    public void metde_Formula_calculations()
    {
        Console.WriteLine("Type the formula name or part of it, or type 'view all formulas'.");
        string search = Console.ReadLine()?.Trim();

        if (search?.ToLower() == "view all formulas")
        {
            ViewAllFormulas();
            return;
        }

        var fields = typeof(Formulas_chemistry).GetFields(BindingFlags.Public | BindingFlags.Static | BindingFlags.FlattenHierarchy);
        bool found = false;

        foreach (var field in fields)
        {
            if (field.IsLiteral && field.FieldType == typeof(string))
            {
                string formulaValue = field.GetValue(null)?.ToString();
                if (!string.IsNullOrEmpty(formulaValue) && formulaValue.Contains(search, StringComparison.OrdinalIgnoreCase))
                {
                    Console.WriteLine($"\nFormula found: {field.Name} = {formulaValue}");
                    found = true;
                    SolveChemistryFormula(field.Name);
                    break;
                }
            }
        }

        if (!found)
            Console.WriteLine("No formula found with this term.");
        Console.WriteLine();
    }

    private void SolveChemistryFormula(string formulaName)
    {
        Console.WriteLine("Enter the values. If a value is unknown, enter 0.");
        double GetDouble(string prompt)
        {
            double val;
            while (true)
            {
                Console.Write(prompt);
                if (double.TryParse(Console.ReadLine(), out val))
                    return val;
                Console.WriteLine("Invalid input. Please enter a number.");
            }
        }

        switch (formulaName)
        {
            case "C1": // M = n / V
                double n = GetDouble("Enter n (moles): ");
                double V = GetDouble("Enter V (volume in liters): ");
                Console.WriteLine($"\nResult: M = {n} / {V} = {n / V} mol/L");
                break;

            case "C2": // PV = nRT
                double P = GetDouble("Enter P (pressure in atm, 0 if unknown): ");
                double V2 = GetDouble("Enter V (volume in L, 0 if unknown): ");
                double n2 = GetDouble("Enter n (moles, 0 if unknown): ");
                double T = GetDouble("Enter T (temperature in K, 0 if unknown): ");
                double R = 0.0821;
                if (P == 0)
                {
                    P = n2 * R * T / V2;
                    Console.WriteLine($"\nResult: P = {n2}×0.0821×{T} / {V2} = {P} atm");
                }
                else if (V2 == 0)
                {
                    V2 = n2 * R * T / P;
                    Console.WriteLine($"\nResult: V = {n2}×0.0821×{T} / {P} = {V2} L");
                }
                else if (n2 == 0)
                {
                    n2 = P * V2 / (R * T);
                    Console.WriteLine($"\nResult: n = {P}×{V2} / (0.0821×{T}) = {n2} mol");
                }
                else if (T == 0)
                {
                    T = P * V2 / (n2 * R);
                    Console.WriteLine($"\nResult: T = {P}×{V2} / ({n2}×0.0821) = {T} K");
                }
                else
                    Console.WriteLine("All values given. No unknown to solve.");
                break;

            case "C3": // pH = -log[H+]
                double H = GetDouble("Enter [H+] concentration: ");
                Console.WriteLine($"\nResult: pH = -log({H}) = {-Math.Log10(H)}");
                break;

            case "C4": // ρ = m / V
                double mass = GetDouble("Enter m (mass in grams): ");
                double vol = GetDouble("Enter V (volume in cm³): ");
                Console.WriteLine($"\nResult: ρ = {mass} / {vol} = {mass / vol} g/cm³");
                break;

            case "C5": // Mass percent
                double solute = GetDouble("Enter mass of solute: ");
                double solution = GetDouble("Enter mass of solution: ");
                Console.WriteLine($"\nResult: Mass % = ({solute}/{solution})×100 = {(solute / solution) * 100} %");
                break;

            case "C6": // ppm
                double solute2 = GetDouble("Enter mass of solute: ");
                double solution2 = GetDouble("Enter mass of solution: ");
                Console.WriteLine($"\nResult: ppm = ({solute2}/{solution2})×10⁶ = {(solute2 / solution2) * 1e6} ppm");
                break;

            case "C7": // Reaction rate
                double deltaA = GetDouble("Enter Δ[A] (change in concentration): ");
                double deltaT = GetDouble("Enter Δt (time change): ");
                Console.WriteLine($"\nResult: Rate = {deltaA} / {deltaT} = {deltaA / deltaT} M/s");
                break;

            case "C8": // Equilibrium constant (simplified example)
                Console.WriteLine("Assuming reaction: aA + bB ⇌ cC + dD");
                double aConc = GetDouble("Enter [A] (M): ");
                double bConc = GetDouble("Enter [B] (M): ");
                double cConc = GetDouble("Enter [C] (M): ");
                double dConc = GetDouble("Enter [D] (M): ");
                double aCoeff = GetDouble("Enter coefficient a: ");
                double bCoeff = GetDouble("Enter coefficient b: ");
                double cCoeff = GetDouble("Enter coefficient c: ");
                double dCoeff = GetDouble("Enter coefficient d: ");
                double Kc = (Math.Pow(cConc, cCoeff) * Math.Pow(dConc, dCoeff)) /
                            (Math.Pow(aConc, aCoeff) * Math.Pow(bConc, bCoeff));
                Console.WriteLine($"\nResult: Kc = {Kc}");
                break;

            case "C9": // Raoult's law
                double Xsolvent = GetDouble("Enter X_solvent (mole fraction of solvent): ");
                double P0 = GetDouble("Enter P°_solvent (pure solvent vapor pressure): ");
                Console.WriteLine($"\nResult: P_solution = {Xsolvent} × {P0} = {Xsolvent * P0} atm");
                break;

            case "C10": // Enthalpy change
                double Hprod = GetDouble("Enter H_products (total enthalpy of products): ");
                double Hreact = GetDouble("Enter H_reactants (total enthalpy of reactants): ");
                Console.WriteLine($"\nResult: ΔH = {Hprod} - {Hreact} = {Hprod - Hreact} kJ");
                break;

            default:
                Console.WriteLine("Calculation for this formula is not implemented yet.");
                break;
        }
    }
}
