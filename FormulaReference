        foreach (var f in fields)
            if (f.IsLiteral && f.FieldType == typeof(string))
                Console.WriteLine($"{i++}. {f.GetValue(null)}");
        Console.WriteLine();
    }

    public void metde_Formula_calculations()
    {
        Console.WriteLine("Type the formula name or part of it, or type 'view all formulas'.");
        string search = Console.ReadLine()?.Trim();

        if (search?.ToLower() == "view all formulas")
        {
            ViewAllFormulas();
            return;
        }

        var fields = typeof(Formulas_mathematics).GetFields(BindingFlags.Public | BindingFlags.Static | BindingFlags.FlattenHierarchy);
        bool found = false;

        foreach (var field in fields)
        {
            if (field.IsLiteral && field.FieldType == typeof(string))
            {
                string formulaValue = field.GetValue(null)?.ToString();
                if (!string.IsNullOrEmpty(formulaValue) && formulaValue.Contains(search, StringComparison.OrdinalIgnoreCase))
                {
                    Console.WriteLine($"\nFormula found: {field.Name} = {formulaValue}");
                    found = true;
                    SolveMathematicsFormula(field.Name);
                    break;
                }
            }
        }

        if (!found)
            Console.WriteLine("No formula found with this term.");
        Console.WriteLine();
    }

    private void SolveMathematicsFormula(string formulaName)
    {
        Console.WriteLine("Enter the values. If a value is unknown, enter 0.");
        double GetDouble(string prompt)
        {
            double val;
            while (true)
            {
                Console.Write(prompt);
                if (double.TryParse(Console.ReadLine(), out val))
                    return val;
                Console.WriteLine("Invalid input. Please enter a number.");
            }
        }
        int GetInt(string prompt)
        {
            int val;
            while (true)
            {
                Console.Write(prompt);
                if (int.TryParse(Console.ReadLine(), out val) && val >= 0)
                    return val;
                Console.WriteLine("Invalid input. Please enter a non-negative integer.");
            }
        }

        switch (formulaName)
        {
            case "M1": // Area of circle
                double r = GetDouble("Enter radius (r): ");
                Console.WriteLine($"\nResult: Area = π × {r}² = {Math.PI * r * r}");
                break;

            case "M2": // Pythagorean
                double a = GetDouble("Enter side a: ");
                double b = GetDouble("Enter side b: ");
                Console.WriteLine($"\nResult: c = √({a}² + {b}²) = {Math.Sqrt(a * a + b * b)}");
                break;

            case "M3": // Quadratic
                double aq = GetDouble("Enter a: ");
                double bq = GetDouble("Enter b: ");
                double cq = GetDouble("Enter c: ");
                double delta = bq * bq - 4 * aq * cq;
                if (delta < 0)
                    Console.WriteLine("No real roots.");
                else
                {
                    double x1 = (-bq + Math.Sqrt(delta)) / (2 * aq);
                    double x2 = (-bq - Math.Sqrt(delta)) / (2 * aq);
                    Console.WriteLine($"\nResult: x1 = {x1}, x2 = {x2}");
                }
                break;

            case "M4": // Volume of sphere
                double r2 = GetDouble("Enter radius (r): ");
                Console.WriteLine($"\nResult: Volume = (4/3)π × {r2}³ = {(4.0 / 3.0) * Math.PI * Math.Pow(r2, 3)}");
                break;

            case "M5": // Area of triangle
                double baseLen = GetDouble("Enter base: ");
                double height = GetDouble("Enter height: ");
                Console.WriteLine($"\nResult: Area = ½ × {baseLen} × {height} = {0.5 * baseLen * height}");
                break;

            case "M6": // Circumference
                double r3 = GetDouble("Enter radius (r): ");
                Console.WriteLine($"\nResult: Circumference = 2π × {r3} = {2 * Math.PI * r3}");
                break;

            case "M7": // Area of rectangle
                double len = GetDouble("Enter length: ");
                double wid = GetDouble("Enter width: ");
                Console.WriteLine($"\nResult: Area = {len} × {wid} = {len * wid}");
                break;

            case "M8": // Volume of cylinder
                double r4 = GetDouble("Enter radius (r): ");
                double h = GetDouble("Enter height (h): ");
                Console.WriteLine($"\nResult: Volume = π × {r4}² × {h} = {Math.PI * r4 * r4 * h}");
                break;

            case "M9": // Area of trapezoid
                double a2 = GetDouble("Enter side a: ");
                double b2 = GetDouble("Enter side b: ");
                double h2 = GetDouble("Enter height (h): ");
                Console.WriteLine($"\nResult: Area = ½({a2}+{b2})×{h2} = {0.5 * (a2 + b2) * h2}");
                break;

            case "M10": // Factorial
                int n = GetInt("Enter n (non-negative): ");
                long fact = 1;
                for (int i = 1; i <= n; i++) fact *= i;
                Console.WriteLine($"\nResult: {n}! = {fact}");
                break;

            default:
                Console.WriteLine("Calculation for this formula is not implemented yet.");
                break;
        }
    }
}

